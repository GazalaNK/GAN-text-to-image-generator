import matplotlib.pyplot as plt
from PIL import Image
from scipy.io import loadmat

image_folder="/content/drive/MyDrive/Flowers102"

image_files = []
image_extensions = ('.jpg', '.jpeg', '.png', '.gif', '.bmp', '.tiff')

# Use os.walk to find all image files in the directory and its subdirectories
for root, dirs, files in os.walk(image_folder):
    for file in files:
        if file.lower().endswith(image_extensions):
            image_files.append(os.path.join(root, file))

print("Total Images found:", len(image_files))
print("First 5 image paths:", image_files[:5])

if image_files:
    img_path = image_files[0] # Corrected: access first element directly
    print(f"Opening image: {img_path}")
    img = Image.open(img_path)
    plt.imshow(img)
    plt.axis("off")
    plt.title(os.path.basename(img_path)) # Display filename as title
    plt.show()
else:
    print("No image files found in the specified directory or its subdirectories.")
print("image size:",img.size)

